          "destination": "${projectName}_db"
        },
        {
          "type": "run",
          "executable": "${php}",
          "arguments": "${tools}/wp-cli/wp-cli.phar core download --path=${www}/${projectName}",
          "workingDirectory": "${www}",
          "timeoutMs": 600000
        },
        {
          "type": "run",
          "executable": "${php}",
          "arguments": "${tools}/wp-cli/wp-cli.phar config create --path=${www}/${projectName} --dbname=${dbName} --dbuser=${dbUser} --dbpass=${dbPassword} --dbhost=${dbHost}:${dbPort} --skip-check",
          "workingDirectory": "${www}",
          "timeoutMs": 120000,
          "requiresDatabase": true
        },
        {
          "type": "run",
          "executable": "${php}",
          "arguments": "${tools}/wp-cli/wp-cli.phar core install --path=${www}/${projectName} --url=http://${projectName}/ --title=${projectName} --admin_user=admin --admin_email=admin@${projectName}.local --skip-email",
          "workingDirectory": "${www}",
          "timeoutMs": 300000,
          "requiresDatabase": true
        }
      ]
    }
  ]
}
