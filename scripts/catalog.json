{
  "schemaVersion": 1,
  "items": [
    {
      "id": "akaunting",
      "name": "Akaunting",
      "category": "Accounting",
      "summary": "Clone Akaunting, create its database, install Composer dependencies, and run its non-interactive installer.",
      "homepage": "https://akaunting.com/",
      "license": "BSL",
      "version": "latest",
      "postInstallNotes": "Log in with email `admin@${projectName}.local` and the generated admin password shown in the install log above. Akaunting's upstream installation guide also includes `npm install` and `npm run dev`; run those inside the project if you need to rebuild frontend assets locally.",
      "install": [
        {
          "type": "run",
          "executable": "${tools}/git/bin/git.exe",
          "arguments": "clone --depth 1 https://github.com/akaunting/akaunting.git ${www}/${projectName}",
          "workingDirectory": "${www}",
          "timeoutMs": 900000
        },
        {
          "type": "create_database_user",
          "destination": "${projectName}_db"
        },
        {
          "type": "run",
          "executable": "${php}",
          "arguments": "${tools}/composer/composer.phar install --no-interaction",
          "workingDirectory": "${www}/${projectName}",
          "timeoutMs": 900000
        },
        {
          "type": "run",
          "executable": "${php}",
          "arguments": "artisan install --db-name=${dbName} --db-username=${dbUser} --db-password=${dbPassword} --admin-email=admin@${projectName}.local --admin-password=${adminPassword}",
          "workingDirectory": "${www}/${projectName}",
          "timeoutMs": 900000,
          "requiresDatabase": true
        }
      ]
    },
