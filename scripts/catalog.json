    {
      "id": "woocommerce",
      "name": "WooCommerce",
      "category": "E-commerce CMS",
      "summary": "Download WordPress, wire up the database, install WordPress, then install WooCommerce with WP-CLI.",
      "homepage": "https://woocommerce.com/",
      "license": "GPL-3.0-or-later",
      "version": "latest",
      "adminPath": "/wp-admin",
      "postInstallNotes": "Log in with username 'admin' and the password WP-CLI generated during install (printed once in the install log above). WooCommerce's setup wizard runs on first admin login.",
      "install": [
        {
          "type": "create_directory",
          "destination": "${www}/${projectName}"
        },
        {
          "type": "create_database_user",
          "destination": "${projectName}_db"
        },
        {
          "type": "run",
          "executable": "${php}",
          "arguments": "${tools}/wp-cli/wp-cli.phar core download --path=${www}/${projectName}",
          "workingDirectory": "${www}",
          "timeoutMs": 600000
        },
        {
          "type": "run",
          "executable": "${php}",
          "arguments": "${tools}/wp-cli/wp-cli.phar config create --path=${www}/${projectName} --dbname=${dbName} --dbuser=${dbUser} --dbpass=${dbPassword} --dbhost=${dbHost}:${dbPort} --skip-check",
          "workingDirectory": "${www}",
          "timeoutMs": 120000,
          "requiresDatabase": true
        },
        {
          "type": "run",
          "executable": "${php}",
          "arguments": "${tools}/wp-cli/wp-cli.phar core install --path=${www}/${projectName} --url=http://${projectName}/ --title=${projectName} --admin_user=admin --admin_email=admin@${projectName}.local --skip-email",
          "workingDirectory": "${www}",
          "timeoutMs": 300000,
          "requiresDatabase": true
        },
        {
          "type": "run",
          "executable": "${php}",
          "arguments": "${tools}/wp-cli/wp-cli.phar plugin install woocommerce --activate --path=${www}/${projectName}",
          "workingDirectory": "${www}",
          "timeoutMs": 600000,
          "requiresDatabase": true
        }
      ]
    },
