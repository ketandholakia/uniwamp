    {
      "id": "ecotone-lite",
      "name": "Ecotone Lite",
      "category": "PHP Framework",
      "summary": "Create a minimal PSR-4 Composer project and install Ecotone Lite.",
      "homepage": "https://docs.ecotone.tech/install-php-service-bus",
      "license": "MIT",
      "version": "recommended",
      "postInstallNotes": "Ecotone Lite is framework-agnostic rather than a full MVC web framework. UniWAMP created a minimal Composer project with PSR-4 autoloading, installed ecotone/lite-application, and added a placeholder /public/index.php so the vhost resolves cleanly. Add your application classes under src and bootstrap Ecotone Lite per the official installation guide.",
      "install": [
        {
          "type": "create_directory",
          "destination": "${www}/${projectName}"
        },
        {
          "type": "create_directory",
          "destination": "${www}/${projectName}/src"
        },
        {
          "type": "create_directory",
          "destination": "${www}/${projectName}/public"
        },
        {
          "type": "write_file",
          "destination": "${www}/${projectName}/composer.json",
          "content": "{\n  \"name\": \"uniwamp/${projectName}\",\n  \"type\": \"project\",\n  \"require\": {\n    \"php\": \">=8.1\",\n    \"ecotone/lite-application\": \"*\"\n  },\n  \"autoload\": {\n    \"psr-4\": {\n      \"App\\\\\": \"src/\"\n    }\n  },\n  \"minimum-stability\": \"stable\",\n  \"prefer-stable\": true\n}\n"
        },
        {
          "type": "write_file",
          "destination": "${www}/${projectName}/public/index.php",
          "content": "<?php\n\ndeclare(strict_types=1);\n\nheader('Content-Type: text/plain; charset=utf-8');\n\necho \"Ecotone Lite project created.\\n\";\necho \"Add your application classes under src and bootstrap Ecotone Lite according to the official docs.\\n\";\n"
        },
        {
          "type": "run",
          "executable": "${php}",
          "arguments": "${tools}/composer/composer.phar install --no-interaction",
          "workingDirectory": "${www}/${projectName}",
          "timeoutMs": 600000
        }
      ]
    },
