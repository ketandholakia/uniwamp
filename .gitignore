# ============================================================
# UniWamp – project-specific ignores
# ============================================================
/bin/
/runtime/
/logs/*
!/logs/.gitkeep
/tmp/*
!/tmp/.gitkeep

# Third-party dashboard template artifacts
/tailadmin-free-tailwind-dashboard-template-main/node_modules/
/tailadmin-free-tailwind-dashboard-template-main/build/

